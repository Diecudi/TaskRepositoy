<style>
    /* Variables para el Tema Claro / Oscuro */
    :root {
        --bg-color: #f4f5f7;
        --text-color: #172b4d;
        --card-bg: #ffffff;
        --board-bg: #ebecf0;
        --border-color: #dfe1e6;
    }

    [data-theme="dark"] {
        --bg-color: #1d2125;
        --text-color: #b6c2cf;
        --card-bg: #22272b;
        --board-bg: #161a1d;
        --border-color: #3b4045;
    }

    body {
        background-color: var(--bg-color);
        color: var(--text-color);
        transition: background-color 0.3s ease, color 0.3s ease;
    }

    /* Estilos del Tablero Kanban */
    .kanban-board {
        display: flex;
        gap: 1.5rem;
        overflow-x: auto;
        padding-bottom: 1rem;
        align-items: flex-start;
    }

    .task-card {
        background-color: var(--card-bg);
        color: var(--text-color);
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 12px;
        cursor: grab;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
        border: 1px solid var(--border-color);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .task-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.15);
    }

    /* Estilos del Sidebar de Proyectos */
    .sidebar-proyectos {
        background-color: var(--board-bg);
        border-right: 1px solid var(--border-color);
        min-height: calc(100vh - 120px);
        padding: 1.5rem 1rem;
        border-radius: 10px;
    }

    /* Estilos para nav-pills de proyectos */
    .nav-pills .nav-link {
        color: var(--text-color);
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        transition: all 0.2s;
    }
    .nav-pills .nav-link.active {
        background-color: #0d6efd;
        color: #fff;
        border-color: #0d6efd;
    }

    /* Sobrescribir colores de los tabs para modo nocturno */
    .nav-tabs {
        border-bottom-color: var(--border-color);
    }
    .nav-tabs .nav-link {
        color: var(--text-color);
    }
    .nav-tabs .nav-link.active {
        background-color: var(--bg-color);
        border-color: var(--border-color) var(--border-color) var(--bg-color);
        color: var(--text-color);
    }

    /* Animaciones */
    .fade-in {
        animation: fadeIn 0.6s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<div class="container-fluid fade-in mt-4">
    <!-- Cabecera del Dashboard -->
    <header class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom" style="border-color: var(--border-color) !important;">
        <div class="d-flex align-items-center gap-3">
            <h2 class="mb-0 fw-bold">JiraClone</h2>
            <span class="badge bg-primary rounded-pill">Sprint 1</span>
            <button class="btn btn-sm btn-outline-primary rounded-pill" data-bs-toggle="modal" data-bs-target="#addSprintModal">Nuevo Sprint</button>
        </div>
        
        <div class="d-flex align-items-center gap-3">
            <!-- Perfil de Usuario con Foto -->
            <div class="d-flex align-items-center gap-2">
                <span>User Admin</span>
                <img src="https://ui-avatars.com/api/?name=User+Admin&background=0D8ABC&color=fff" class="rounded-circle shadow-sm" width="45" height="45" alt="Perfil">
            </div>
        </div>
    </header>

    <div class="row">
        <!-- Sidebar de Proyectos -->
        <div class="col-lg-2 col-md-3 mb-4">
            <div class="sidebar-proyectos">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="mb-0 fw-bold text-uppercase text-secondary">Proyectos</h6>
                    <button class="btn btn-sm btn-primary rounded-circle" data-bs-toggle="modal" data-bs-target="#addProjectModal" title="Nuevo Proyecto" style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;">+</button>
                </div>
                <div class="nav flex-column nav-pills gap-2" id="project-tabs" role="tablist" aria-orientation="vertical">
                    <!-- Proyectos dinámicos -->
                </div>
            </div>
        </div>

        <!-- Contenido Principal -->
        <div class="col-lg-10 col-md-9">
            <!-- Navegación de Vistas -->
            <ul class="nav nav-tabs mb-4" id="jiraTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold" id="tablero-tab" data-bs-toggle="tab" data-bs-target="#tablero" type="button" role="tab" aria-controls="tablero" aria-selected="true">Tablero</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold" id="backlog-tab" data-bs-toggle="tab" data-bs-target="#backlog" type="button" role="tab" aria-controls="backlog" aria-selected="false">Backlog</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold" id="cronograma-tab" data-bs-toggle="tab" data-bs-target="#cronograma" type="button" role="tab" aria-controls="cronograma" aria-selected="false">Cronograma</button>
                </li>
            </ul>

            <div class="tab-content" id="jiraTabContent">
                <!-- VISTA: TABLERO KANBAN -->
                <div class="tab-pane fade show active" id="tablero" role="tabpanel" aria-labelledby="tablero-tab">
                    <div id="sprintsContainer">
                        <!-- Swimlanes de los Sprints generados automáticamente -->
                    </div>
                </div>

                <!-- VISTA: BACKLOG -->
                <div class="tab-pane fade" id="backlog" role="tabpanel" aria-labelledby="backlog-tab">
                    <div class="row mb-4">
                        <div class="col d-flex gap-2">
                            <button class="btn btn-primary fw-bold" data-bs-toggle="modal" data-bs-target="#addTaskModal">Añadir Tarea</button>
                        </div>
                    </div>
                    
                    <div class="card" style="background-color: var(--card-bg); border-color: var(--border-color);">
                        <div class="card-header fw-bold" style="background-color: var(--board-bg); border-bottom-color: var(--border-color); color: var(--text-color);">
                            Backlog General
                        </div>
                        <div class="card-body p-0">
                            <ul class="list-group list-group-flush" id="backlogList">
                                <!-- Items del backlog se cargarán aquí -->
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- VISTA: CRONOGRAMA -->
                <div class="tab-pane fade" id="cronograma" role="tabpanel" aria-labelledby="cronograma-tab">
                    <div class="alert alert-info" role="alert" style="background-color: var(--card-bg); border-color: var(--border-color); color: var(--text-color);">
                        <strong>Cronograma (Roadmap)</strong> - Aquí se visualizará el diagrama de Gantt de los Sprints.
                    </div>
                    <div class="d-flex align-items-center justify-content-center mt-4" style="height: 250px; background-color: var(--board-bg); border-radius: 8px; border: 1px dashed var(--border-color);">
                        <span class="text-muted fw-bold">Próximamente: Gráfico de Cronograma</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL: AÑADIR TAREA -->
    <div class="modal fade" id="addTaskModal" tabindex="-1" aria-labelledby="addTaskModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" style="background-color: var(--card-bg); color: var(--text-color);">
                <div class="modal-header" style="border-bottom-color: var(--border-color);">
                    <h5 class="modal-title fw-bold" id="addTaskModalLabel">Añadir Nueva Tarea</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="taskForm">
                        <div class="mb-3">
                            <label for="taskTitle" class="form-label">Nombre de la tarea</label>
                            <input type="text" class="form-control" id="taskTitle" required>
                        </div>
                        <div class="mb-3">
                            <label for="taskUser" class="form-label">Usuario Asignado</label>
                            <select class="form-select" id="taskUser">
                                <option value="User Admin">User Admin</option>
                                <option value="User 2">User 2</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="taskType" class="form-label">Tipo de Tarea</label>
                            <select class="form-select" id="taskType">
                                <option value="Historia">Historia</option>
                                <option value="Bug">Bug (Error)</option>
                                <option value="Tarea">Tarea</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="taskSprint" class="form-label">Sprint (Opcional)</label>
                            <select class="form-select" id="taskSprint">
                                <option value="0">(Sin Sprint / Backlog)</option>
                            </select>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="taskStartDate" class="form-label">Fecha de Inicio</label>
                                <input type="date" class="form-control" id="taskStartDate">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="taskEndDate" class="form-label">Fecha de Fin</label>
                                <input type="date" class="form-control" id="taskEndDate">
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer" style="border-top-color: var(--border-color);">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" onclick="addTask()">Guardar Tarea</button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL: AÑADIR PROYECTO -->
    <div class="modal fade" id="addProjectModal" tabindex="-1" aria-labelledby="addProjectModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" style="background-color: var(--card-bg); color: var(--text-color);">
                <div class="modal-header" style="border-bottom-color: var(--border-color);">
                    <h5 class="modal-title fw-bold" id="addProjectModalLabel">Crear Proyecto</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="projectForm">
                        <div class="mb-3">
                            <label for="projectName" class="form-label">Nombre del Proyecto</label>
                            <input type="text" class="form-control" id="projectName" required>
                        </div>
                        <div class="mb-3">
                            <label for="projectDesc" class="form-label">Descripción</label>
                            <textarea class="form-control" id="projectDesc" rows="3"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer" style="border-top-color: var(--border-color);">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" onclick="addProject()">Crear Proyecto</button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL: AÑADIR SPRINT -->
    <div class="modal fade" id="addSprintModal" tabindex="-1" aria-labelledby="addSprintModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" style="background-color: var(--card-bg); color: var(--text-color);">
                <div class="modal-header" style="border-bottom-color: var(--border-color);">
                    <h5 class="modal-title fw-bold" id="addSprintModalLabel">Crear Sprint</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="sprintForm">
                        <div class="mb-3">
                            <label for="sprintName" class="form-label">Nombre del Sprint</label>
                            <input type="text" class="form-control" id="sprintName" placeholder="Ej. Sprint 2" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="sprintStartDate" class="form-label">Fecha de Inicio</label>
                                <input type="date" class="form-control" id="sprintStartDate">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="sprintEndDate" class="form-label">Fecha de Fin</label>
                                <input type="date" class="form-control" id="sprintEndDate">
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer" style="border-top-color: var(--border-color);">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" onclick="addSprint()">Crear Sprint</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<!-- SortableJS para Drag & Drop -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<!-- Aseguramos que Bootstrap JS está cargado para que funcionen las pestañas -->
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

<script>
let currentProjectId = 0;

$(document).ready(function () {
    loadProjects();
    
    // Funcionalidad al hacer clic en los proyectos
    $(document).on('shown.bs.tab', 'button[data-bs-toggle="pill"]', function (e) {
        $(e.target).removeClass('text-muted');
        $(e.relatedTarget).addClass('text-muted');
    });
});

function loadProjects() {
    $.get('/Task/GetProjects', function(projects) {
        $('#project-tabs').empty();
        if(projects.length > 0) {
            projects.forEach((p, index) => {
                let isActive = index === 0 ? 'active' : 'text-muted';
                $('#project-tabs').append(`<button class="nav-link mb-2 fw-bold text-start ${isActive}" data-bs-toggle="pill" type="button" role="tab" onclick="selectProject(${p.id})">${p.name}</button>`);
            });
            selectProject(projects[0].id);
        } else {
            $('#sprintsContainer').html('<div class="text-center mt-5 text-muted">No hay proyectos. Crea uno primero.</div>');
            $('#project-tabs').append('<span class="text-muted small">Sin proyectos</span>');
            currentProjectId = 0;
        }
    });
}

function selectProject(id) {
    currentProjectId = id;
    $('#project-tabs button').removeClass('active').addClass('text-muted');
    $(`#project-tabs button[onclick="selectProject(${id})"]`).addClass('active').removeClass('text-muted');
    loadDashboard();
}

function loadDashboard() {
    if(currentProjectId === 0) return;
    
    $.get('/Task/GetSprints?projectId=' + currentProjectId, function(sprints) {
        let sprintSelect = $('#taskSprint');
        sprintSelect.empty();
        sprintSelect.append('<option value="0">(Sin Sprint / Backlog)</option>');
        
        let container = $('#sprintsContainer');
        container.empty();

        // 1. Crear Swimlanes por Sprint
        sprints.forEach(s => {
            sprintSelect.append(`<option value="${s.id}">${s.name}</option>`);
            container.append(createSwimlaneHtml(s.id, s.name, s.startDate, s.endDate));
        });
        
        // 2. Crear Swimlane para el Backlog (Tareas sin Sprint)
        container.append(createSwimlaneHtml(0, 'Backlog General', '', ''));

        // 3. Cargar Tareas
        $.get('/Task/GetTasks?projectId=' + currentProjectId, function(tasks) {
            $('#backlogList').empty();

            tasks.forEach(task => {
                let sId = task.sprintId || 0;
                let card = `<div class="task-card shadow-sm fade-in" data-id="${task.id}"><div class="fw-bold">${task.title}</div><small class="text-muted">TASK-${task.id}</small></div>`;
                
                if(task.status === 1) $(`#inProgressList_${sId}`).append(card);
                else if (task.status === 2) $(`#doneList_${sId}`).append(card);
                else $(`#todoList_${sId}`).append(card);

                $('#backlogList').append(`<li class="list-group-item d-flex justify-content-between align-items-center" style="background-color: var(--card-bg); color: var(--text-color); border-color: var(--border-color);"><div><span class="fw-bold me-2">TASK-${task.id}</span><span>${task.title}</span></div><span class="badge bg-secondary rounded-pill">Status: ${task.status}</span></li>`);
            });
            initSortable();
        });
    });
}

function createSwimlaneHtml(sprintId, name, start, end) {
    let dates = start ? `<span class="badge bg-info text-dark ms-2 fw-normal">${start} - ${end}</span>` : '';
    return `
    <div class="sprint-swimlane mb-5 p-3 rounded shadow-sm" style="background-color: var(--board-bg); border: 1px solid var(--border-color);">
        <h5 class="fw-bold text-primary mb-3 pb-2 border-bottom" style="border-color: var(--border-color) !important;">${name} ${dates}</h5>
        <div class="d-flex gap-3 overflow-x-auto">
            <div class="flex-fill" style="min-width: 250px;">
                <h6 class="text-uppercase fw-bold text-secondary mb-2">To Do</h6>
                <div id="todoList_${sprintId}" class="task-list sortable-list rounded p-2" data-status="0" data-sprint-id="${sprintId}" style="min-height: 120px; background-color: var(--card-bg); border: 1px dashed var(--border-color);"></div>
            </div>
            <div class="flex-fill" style="min-width: 250px;">
                <h6 class="text-uppercase fw-bold text-secondary mb-2">In Progress</h6>
                <div id="inProgressList_${sprintId}" class="task-list sortable-list rounded p-2" data-status="1" data-sprint-id="${sprintId}" style="min-height: 120px; background-color: var(--card-bg); border: 1px dashed var(--border-color);"></div>
            </div>
            <div class="flex-fill" style="min-width: 250px;">
                <h6 class="text-uppercase fw-bold text-secondary mb-2">Done</h6>
                <div id="doneList_${sprintId}" class="task-list sortable-list rounded p-2" data-status="2" data-sprint-id="${sprintId}" style="min-height: 120px; background-color: var(--card-bg); border: 1px dashed var(--border-color);"></div>
            </div>
        </div>
    </div>`;
}

function initSortable() {
    const sortableOptions = {
        group: 'kanban',
        animation: 150,
        ghostClass: 'opacity-50',
        onEnd: function (evt) {
            const taskId = evt.item.getAttribute('data-id');
            const newStatus = evt.to.getAttribute('data-status');
            const newSprintId = evt.to.getAttribute('data-sprint-id');

            if (taskId) {
                $.post('/Task/UpdateTaskStatus', { id: taskId, status: newStatus, sprintId: newSprintId });
            }
        }
    };
    $('.sortable-list').each(function() { new Sortable(this, sortableOptions); });
}

function addTask() {
    if(currentProjectId === 0) return alert('Debes seleccionar un proyecto primero');
    let title = $('#taskTitle').val();
    let user = $('#taskUser').val();
    let type = $('#taskType').val();
    let startDate = $('#taskStartDate').val();
    let endDate = $('#taskEndDate').val();
    let sprintId = $('#taskSprint').val();
    
    if(!title) return;

    $.post('/Task/AddTask', { 
        title: title,
        assignedUser: user,
        taskType: type,
        startDate: startDate,
        endDate: endDate,
        projectId: currentProjectId,
        sprintId: sprintId
    }, function() {
        $('#taskForm')[0].reset();
        $('#addTaskModal').modal('hide');
        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open').css('padding-right', '');
        loadDashboard();
    });
}

function addProject() {
    let name = $('#projectName').val();
    let desc = $('#projectDesc').val();
    if(!name) return;
    
    $.post('/Task/AddProject', { name: name, description: desc }, function() {
        $('#projectForm')[0].reset();
        $('#addProjectModal').modal('hide');
        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open').css('padding-right', '');
        loadProjects();
    });
}

function addSprint() {
    if(currentProjectId === 0) return alert('Debes seleccionar un proyecto primero');
    let name = $('#sprintName').val();
    let start = $('#sprintStartDate').val();
    let end = $('#sprintEndDate').val();
    if(!name || !start || !end) return;
    
    $.post('/Task/AddSprint', { name: name, startDate: start, endDate: end, projectId: currentProjectId }, function() {
        $('#sprintForm')[0].reset();
        $('#addSprintModal').modal('hide');
        $('.modal-backdrop').remove();
        $('body').removeClass('modal-open').css('padding-right', '');
        loadDashboard();
    });
}
</script>